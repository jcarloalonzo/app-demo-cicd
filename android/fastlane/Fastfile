default_platform(:android)

platform :android do
  # desc "Deploy staging App Bundle to Play Store Internal"
  # lane :deploy_staging do
  #   # Setup keystore
  #   setup_staging_keystore
    
  #   # Build App Bundle
  #   Dir.chdir("../") do
  #     sh("flutter", "build", "appbundle", "--flavor", "staging", "-t", "lib/main_staging.dart", "--release")
