  #   )
  # end

  desc "Deploy production App Bundle to Play Store"
  lane :deploy_production do
    
    # Setup keystore
    UI.message("🚀 Starting deploy_production lane")
    setup_production_keystore
    UI.success("✅ Keystore configurado correctamente")
    
    # Build App Bundle
    Dir.chdir("../") do
      UI.message("💻 Compilando App Bundle (flavor: production)…")
      # sh("flutter", "build", "appbundle", "--flavor", "production", "-t", "lib/main_production.dart", "--release")
      sh("flutter build appbundle --flavor production -t lib/main_production.dart --release")
      UI.success("📦 App Bundle construido en build/app/outputs/bundle/productionRelease/")
    end

    UI.message("☁️ Subiendo a Google Play (track: production)…")
    # Upload to Play Store
    upload_to_play_store(
      # Usar track 'production' para producción
      track: 'internal', 
      # json_key: ENV['PLAY_STORE_CONFIG_JSON'],
      json_key: 'fastlane/playstore-credential.json',
      package_name: 'com.jelafintegradores.democicd',
      aab: '../build/app/outputs/bundle/productionRelease/app-production-release.aab',
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
      # skip_upload_changelogs: false,
      release_status: 'completed' # 'draft' para pruebas, 'completed' para producción
    )
    UI.success("🎉 ¡Upload completado!")
  end


private_lane :setup_production_keystore do
  # Crear el keystore en android/app/ (no en fastlane/app/)
  sh("mkdir -p ../app")
  
  # DEBUG info...
  UI.message("📋 KEYSTORE_BASE64 primeros 50 chars: #{ENV['KEYSTORE_BASE64'].to_s[0..49]}")
  UI.message("📋 KEYSTORE_BASE64 últimos 50 chars: #{ENV['KEYSTORE_BASE64'].to_s[-50..-1]}")
  UI.message("📋 KEYSTORE_BASE64 length: #{ENV['KEYSTORE_BASE64'].to_s.length}")
  
  # Decodificar usando Ruby
  require 'base64'
  keystore_data = Base64.decode64(ENV['KEYSTORE_BASE64'])
  
  # Escribir el keystore en android/app/
  File.open("../app/production-keystore.jks", "wb") do |file|
    file.write(keystore_data)
  end
  
  # Crear key.production.properties en android/ (no en fastlane/)
  File.open("../key.production.properties", "w") do |file|
    file.puts "storePassword=#{ENV['STORE_PASSWORD']}"
    file.puts "keyPassword=#{ENV['KEY_PASSWORD']}"
    file.puts "keyAlias=#{ENV['KEY_ALIAS']}"
    file.puts "storeFile=production-keystore.jks"
  end
  
  # Verificar
  UI.message("🔍 Verificando SHA1 del keystore:")
  sh("keytool -list -v -keystore ../app/production-keystore.jks -alias #{ENV['KEY_ALIAS']} -storepass #{ENV['STORE_PASSWORD']} -keypass #{ENV['KEY_PASSWORD']} | grep SHA1:")
  
  # Debug de ubicaciones
  UI.message("📂 Archivos creados:")
  sh("ls -la ../app/production-keystore.jks")
  sh("ls -la ../key.production.properties")
end  


end