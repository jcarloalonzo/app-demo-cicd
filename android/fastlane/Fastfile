  # 2) Compila APK
  private_lane :build_apk do |options|
    env = options[:environment].to_sym
    config = ENVIRONMENTS[env]

    UI.message("💻 Compilando APK (flavor: #{env})…")
    Dir.chdir("../") do
      sh("flutter build apk --flavor #{env} -t lib/main_#{env}.dart --release")
      UI.success("📦 APK generado en #{config[:apk_path]}")
    end
  end

  # 2) Compila AAB
  private_lane :build_aab do |options|
    env = options[:environment].to_sym
    config = ENVIRONMENTS[env]

    UI.message("💻 Compilando AAB (flavor: #{env})…")
    Dir.chdir("../") do
      sh("flutter build appbundle --flavor #{env} -t lib/main_#{env}.dart --release")
      UI.success("📦 AAB generado en #{config[:aab_path]}")
    end
  end

  # 
  # 
  # 
  # 
  # 

  desc "Build y deploy a Google Play para el ambiente especificado"
  lane :deploy do |options|
    env = options[:environment] 
    UI.header("🚀 DEPLOY #{env.to_s.upcase} A GOOGLE PLAY")

    # Validar ambiente
    unless ENVIRONMENTS.key?(env.to_sym)
      UI.user_error!("❌ Ambiente inválido: #{env}. Opciones: #{ENVIRONMENTS.keys.join(', ')}")
    end

    config = ENVIRONMENTS[env.to_sym]
    UI.message("🌍 Configuración para #{env}: #{config}")
    # 1) Setup keystore
    setup_keystore(environment: env)

    # 2) Build appbundle
    build_aab(environment: env)

    # 3) Upload a Play Store
    UI.message("☁️ Subiendo AAB a Google Play (track: #{config[:track]})…")
    upload_to_play_store(
      track:           config[:track],
      json_key:        COMMON[:json_path],
      package_name:    config[:package_name],
      aab:             config[:aab_path],
      skip_upload_metadata:    true,
      skip_upload_images:      true,
      skip_upload_screenshots: true,
      skip_upload_changelogs:  true,
      release_status:  config[:release_status]
    )
    UI.success("🎉 Deploy de #{env} completado exitosamente")
  end


  # 1) Decodifica y escribe el keystore en android/app/
  private_lane :setup_keystore do |options|
    env = options[:environment].to_sym
    UI.message("🔑 Configurando keystore para #{env}…")

    # Crear el keystore en android/app/ (no en fastlane/app/)
    sh("mkdir -p ../app")
    # Decodificar usando Ruby
    require 'base64'
    keystore_data = Base64.decode64(ENV['KEYSTORE_BASE64'])

    # Escribir el keystore en android/app/
    File.open("../app/#{env}-keystore.jks", "wb") do |file|
      file.write(keystore_data)
    end

    # Crear key.production.properties en android/ (no en fastlane/)
    File.open("../key.#{env}.properties", "w") do |file|
      file.puts "storePassword=#{ENV['STORE_PASSWORD']}"
      file.puts "keyPassword=#{ENV['KEY_PASSWORD']}"
      file.puts "keyAlias=#{ENV['KEY_ALIAS']}"
      file.puts "storeFile=#{env}-keystore.jks"
    end
    
    # Verificar
    UI.message("🔍 Verificando SHA1 del keystore:")
    sh("keytool -list -v -keystore ../app/#{env}-keystore.jks -alias #{ENV['KEY_ALIAS']} -storepass #{ENV['STORE_PASSWORD']} -keypass #{ENV['KEY_PASSWORD']} | grep SHA1:")
    
    # Debug de ubicaciones
    UI.message("📂 Archivos creados:")
    sh("ls -la ../app/#{env}-keystore.jks")
    sh("ls -la ../key.#{env}.properties")
  end

