# =============================================================================
# FASTLANE TEMPLATE: BUILD Y DEPLOY AAB/APK A GOOGLE PLAY CON FIRMA MANUAL
# =============================================================================
# Este archivo sirve como template para configurar builds y deploys a Google Play
# usando firma manual de código (keystore). Útil cuando no quieres usar match
# o gestión automática de certificados.
#
# REQUISITOS PREVIOS:
# - Keystore de firma (JKS) codificado en Base64 en la variable ENV['KEYSTORE_BASE64']
# - Variables de entorno configuradas:
#     KEYSTORE_BASE64      # contenido del .jks en Base64
#     KEY_ALIAS            # alias de la key en el keystore
#     STORE_PASSWORD       # contraseña del keystore
#     KEY_PASSWORD         # contraseña de la key
#     GOOGLE_PLAY_JSON_KEY_PATH # ruta al JSON de credenciales de Play Store
# ===============================


default_platform(:android)

platform :android do

  COMMON = {
    json_path:   "fastlane/playstore-credential.json"
  }


  ENVIRONMENTS = {
    staging: {
      package_name:  "com.jelafintegradores.democicd.test",
      track:         "internal",
      aab_path:      "../build/app/outputs/bundle/stagingRelease/app-staging-release.aab",
      apk_path:      "../build/app/outputs/apk/stagingRelease/app-staging-release.apk",
      release_status: "draft"              # 'draft' para pruebas, 'completed' para producción
    },
    production: {
      package_name:  "com.jelafintegradores.democicd",
      track:         "internal",
      aab_path:      "../build/app/outputs/bundle/productionRelease/app-production-release.aab",
      apk_path:      "../build/app/outputs/apk/productionRelease/app-production-release.apk",
      release_status: "draft"
    }
  }









  # =============================================================================
  # CALLBACKS COMUNES
  # =============================================================================
  after_all do |lane|
    clean_build_artifacts
    notification(
      subtitle: "Fastlane Android",
      message: "✅ #{lane} completada exitosamente"
    )
  end

  error do |lane, exception|
    clean_build_artifacts
    notification(
      subtitle: "Fastlane Android Error",
      message: "❌ #{lane} falló: #{exception.message}"
    )
  end


  # =============================================================================
  # PRIVATE LANES
  # =============================================================================










