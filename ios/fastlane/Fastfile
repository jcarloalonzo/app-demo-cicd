default_platform(:ios)

platform :ios do





  desc "Deploy Development to Firebase App Distribution"
  lane :deploy_dev do
    build_dev
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_IOS_DEV"],
      firebase_cli_token: ENV["FIREBASE_CLI_TOKEN"],
      groups: "internal-testers",
      release_notes: "iOS Development build - #{ENV['GITHUB_SHA']}"
    )
  end






# 
# 
# 
# 
# 
# 




  desc "Build production TestFlight IPA"
  lane :build_staging do
    UI.message("🔧 [build_staging] Schemes disponibles: #{Actions.lane_context[SharedValues::CONFIGURATION]}")
    UI.message("🔧 [build_staging] Usando scheme ‘production’ y export_method ‘app-store’")
    build_app(
      workspace:        "Runner.xcworkspace",
      scheme:           "production",
      export_method:    "app-store",
      configuration:    "Release",
      output_directory: "./build",
      output_name:      "app-production.ipa"
    )
    UI.success("✅ [build_staging] IPA generada en ./build/app-production.ipa")
  end


  desc "Deploy Staging to TestFlight"
  lane :deploy_staging do
    UI.message("👉 Scheme: production")
    UI.message("👉 API Key ID: #{ENV['APPSTORE_API_KEY_ID']}")
    build_staging
    UI.message("✅ Build complete, uploading to TestFlight…")
    upload_to_testflight(
      api_key: {
        key_id:    ENV["APPSTORE_API_KEY_ID"],
        issuer_id: ENV["APPSTORE_ISSUER_ID"],
        key_content: ENV["APPSTORE_API_PRIVATE_KEY"]
      },
      skip_waiting_for_build_processing: true
    )
  end

  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  desc "Build Production IPA"
  lane :build_production do
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "production",
      export_method: "app-store",
      configuration: "Release",
      output_directory: "./build",
      output_name: "app-production.ipa"
    )
  end  
  # 

  desc "Deploy Production to App Store"
  lane :deploy_production do
    build_production
    upload_to_app_store(
      api_key: {
        key_id: ENV["APPSTORE_API_KEY_ID"],
        issuer_id: ENV["APPSTORE_ISSUER_ID"],
        key_content: ENV["APPSTORE_API_PRIVATE_KEY"]
      },
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false
    )
  end
end