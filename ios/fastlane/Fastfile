default_platform(:ios)

platform :ios do





  desc "Deploy Development to Firebase App Distribution"
  lane :deploy_dev do
    build_dev
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_IOS_DEV"],
      firebase_cli_token: ENV["FIREBASE_CLI_TOKEN"],
      groups: "internal-testers",
      release_notes: "iOS Development build - #{ENV['GITHUB_SHA']}"
    )
  end







  desc "Build production TestFlight IPA con firma manual"
  lane :build_staging do
    UI.message("🔧 [build_staging] Compilando IPA con firma manual…")

    # 1) Fija la firma manual para tu configuración custom "Release-production"
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      targets: ["Runner"],
      build_configurations: ["Release-production"],
      profile_name: "JessmarDistProfileDemo",                           # tu provisioning profile de distribución
      code_sign_identity: "iPhone Distribution: Jessmar Perez (GDQCANTTZ3)"  # el certificado exacto en tu keychain
    )

    # 2) Compila la IPA usando ese perfil y evita que Gym intente detectarlos por su cuenta
    build_app(
      workspace:              "Runner.xcworkspace",
      scheme:                 "production",
      configuration:          "Release-production",
      export_method:          "app-store",
      output_directory:       "./build",
      output_name:            "app-production.ipa",
      skip_profile_detection: true,
      export_options: {
        provisioningProfiles: {
          "com.jelafintegradores.democicd" => "JessmarDistProfileDemo"
        },
        signingStyle: "manual",
        teamID:       "GDQCANTTZ3"
      }
    )

  end

    desc "Deploy Staging a TestFlight"
    lane :deploy_staging do
      UI.message("🚀 [deploy_staging] Iniciando build y upload a TestFlight…")
      build_staging

      UI.message("🔑 API Key ID: #{ENV['APPSTORE_API_KEY_ID']}")
      UI.message("🔑 Issuer ID: #{ENV['APPSTORE_ISSUER_ID']}")
      UI.message("🔑 APPSTORE_API_PRIVATE_KEY: #{ENV['APPSTORE_API_PRIVATE_KEY']}")

      upload_to_testflight(
        api_key: {
          key_id:      ENV["APPSTORE_API_KEY_ID"],
          issuer_id:   ENV["APPSTORE_ISSUER_ID"],
          key_content: ENV["APPSTORE_API_PRIVATE_KEY"]
        },
        skip_waiting_for_build_processing: true
      )
      
      UI.success("🎉 [deploy_staging] IPA subida a TestFlight correctamente")
    end

  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  desc "Build Production IPA"
  lane :build_production do
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "production",
      export_method: "app-store",
      configuration: "Release",
      output_directory: "./build",
      output_name: "app-production.ipa"
    )
  end  
  # 

  desc "Deploy Production to App Store"
  lane :deploy_production do
    build_production
    upload_to_app_store(
      api_key: {
        key_id: ENV["APPSTORE_API_KEY_ID"],
        issuer_id: ENV["APPSTORE_ISSUER_ID"],
        key_content: ENV["APPSTORE_API_PRIVATE_KEY"]
      },
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false
    )
  end
end