default_platform(:ios)

platform :ios do





  desc "Deploy Development to Firebase App Distribution"
  lane :deploy_dev do
    build_dev
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_IOS_DEV"],
      firebase_cli_token: ENV["FIREBASE_CLI_TOKEN"],
      groups: "internal-testers",
      release_notes: "iOS Development build - #{ENV['GITHUB_SHA']}"
    )
  end






# 
# 
# 
# 
# 
# 

  lane :verify_setup do
    UI.message("🔍 Verificando configuración...")
    
    # Verificar identidades de firma
    sh("security find-identity -v -p codesigning")
    
    # Verificar provisioning profiles
    sh("ls -la ~/Library/MobileDevice/Provisioning\\ Profiles/")
    
    # Verificar configuración del proyecto
    sh("xcodebuild -workspace Runner.xcworkspace -scheme production -configuration Release-production -showBuildSettings | grep -E '(PRODUCT_BUNDLE_IDENTIFIER|PROVISIONING_PROFILE|CODE_SIGN_IDENTITY)'")
  end


  platform :ios do
    desc "Build production TestFlight IPA con debug"
    lane :build_staging do
      UI.message("🔧 [build_staging] Compilando IPA…")
      build_app(
        workspace:        "Runner.xcworkspace",
        scheme:           "production",
        export_method:    "app-store",
        configuration:    "Release-production",
        output_directory: "./build",
        output_name:      "app-production.ipa",
        export_options: {
           provisioningProfiles: {
            "com.jelafintegradores.democicd" => "JessmarDistProfileDemo"
          }
        }    

      )
      ipa_path = Actions.lane_context[SharedValues::IPA_OUTPUT_PATH]
      UI.success("✅ [build_staging] IPA generada en: #{ipa_path}")
    end

    desc "Deploy Staging a TestFlight"
    lane :deploy_staging do
      UI.message("🚀 [deploy_staging] Iniciando build y upload a TestFlight…")
      build_staging

      UI.message("🔑 API Key ID: #{ENV['APPSTORE_API_KEY_ID']}")
      UI.message("🔑 Issuer ID: #{ENV['ISSUER_ID']}")

      upload_to_testflight(
        api_key: {
          key_id:      ENV["APPSTORE_API_KEY_ID"],
          issuer_id:   ENV["ISSUER_ID"],
          key_content: ENV["APPSTORE_API_PRIVATE_KEY"]
        },
        skip_waiting_for_build_processing: true
      )
      UI.success("🎉 [deploy_staging] IPA subida a TestFlight correctamente")
    end
  end

  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  # 
  desc "Build Production IPA"
  lane :build_production do
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "production",
      export_method: "app-store",
      configuration: "Release",
      output_directory: "./build",
      output_name: "app-production.ipa"
    )
  end  
  # 

  desc "Deploy Production to App Store"
  lane :deploy_production do
    build_production
    upload_to_app_store(
      api_key: {
        key_id: ENV["APPSTORE_API_KEY_ID"],
        issuer_id: ENV["APPSTORE_ISSUER_ID"],
        key_content: ENV["APPSTORE_API_PRIVATE_KEY"]
      },
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false
    )
  end
end