default_platform(:ios)

platform :ios do
  desc "Build Development IPA"
  lane :build_dev do
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "development",
      export_method: "ad-hoc",
      configuration: "Release",
      output_directory: "./build",
      output_name: "app-dev.ipa"
    )
  end

  desc "Build Staging IPA"
  lane :build_staging do
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "staging",
      export_method: "app-store",
      configuration: "Release",
      output_directory: "./build",
      output_name: "app-staging.ipa"
    )
  end

  desc "Build Production IPA"
  lane :build_production do
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "production",
      export_method: "app-store",
      configuration: "Release",
      output_directory: "./build",
      output_name: "app-production.ipa"
    )
  end

  desc "Deploy Development to Firebase App Distribution"
  lane :deploy_dev do
    build_dev
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_IOS_DEV"],
      firebase_cli_token: ENV["FIREBASE_CLI_TOKEN"],
      groups: "internal-testers",
      release_notes: "iOS Development build - #{ENV['GITHUB_SHA']}"
    )
  end

  desc "Deploy Staging to TestFlight"
  lane :deploy_staging do
    build_staging
    upload_to_testflight(
      api_key: {
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
      },
      skip_waiting_for_build_processing: true
    )
  end

  desc "Deploy Production to App Store"
  lane :deploy_production do
    build_production
    upload_to_app_store(
      api_key: {
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
      },
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false
    )
  end
end